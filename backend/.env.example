# Agricultural Market Intelligence API - Environment Configuration

# ============================================
# SERVER CONFIGURATION
# ============================================

# Port to run the server on (default: 5000)
PORT=5000

# Node environment (development, production, test)
NODE_ENV=development

# ============================================
# API KEY CONFIGURATION
# ============================================

# Agmarknet API Key (Required)
# Get your API key from: https://data.gov.in/
API_KEY=579b464db66ec23bdd0000017954c766c08b48836cca314f2ac28314

# ============================================
# CORS CONFIGURATION
# ============================================

# CORS Origin (comma-separated if multiple origins)
# Allow frontend to communicate with backend
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:3001

# ============================================
# OPTIONAL SETTINGS
# ============================================

# Enable debug logging
DEBUG=false

# Cache TTL in seconds (default: 300 = 5 minutes)
CACHE_TTL=300

# Maximum records to fetch per API call
MAX_RECORDS=200

# Request timeout in milliseconds
REQUEST_TIMEOUT=10000
